# ── Cloudflare R2 (data patch storage) ─────────────────────────────
# Public read URL (no auth needed for consumers):
R2_PUBLIC_URL=
# Push credentials (needed for `make push`):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=flipcommons-ingest-sources
#
# Patches ship under the flippatch/ prefix of the shared bucket; the catalog
# (pindata) lives under pindata/ and pinexplore ingest sources at the root.
